# Keep disabled until the live token and package defaults are configured.
DELHIVERY_ENABLED=false
DELHIVERY_API_TOKEN=replace_with_live_delhivery_token
DELHIVERY_PICKUP_LOCATION=UK German Pharmaceuticals
DELHIVERY_BASE_URL=https://track.delhivery.com

# Dummy package defaults; replace with actual packed parcel measurements.
DELHIVERY_DEFAULT_WEIGHT_GRAMS=500
DELHIVERY_DEFAULT_LENGTH_CM=20
DELHIVERY_DEFAULT_WIDTH_CM=15
DELHIVERY_DEFAULT_HEIGHT_CM=10

# Set false if Delhivery has enabled a daily automatic pickup on your account.
DELHIVERY_AUTO_PICKUP=true
DELHIVERY_PICKUP_TIME=16:00:00
